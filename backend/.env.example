# Copy this file to .env and fill in real values. .env is git-ignored.

NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string (cluster URI + db name)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/wanderly

# Origin allowed to call this API with credentials (the Vite dev server, or
# the deployed Vercel URL in production)
CLIENT_ORIGIN=http://localhost:5173

# --- Added in later phases (auth, payments, images) — not required yet ---
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# REDIS_URL=
