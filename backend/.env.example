# Copy this file to .env and fill in real values. .env is git-ignored.

NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string (cluster URI + db name)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/wanderly

# Origin(s) allowed to call this API with credentials — comma-separated for
# multiple (e.g. prod Vercel domain + preview deployments).
CLIENT_ORIGIN=http://localhost:5173

# debug | info | warn | error (defaults: dev=debug, test=error, prod=info)
LOG_LEVEL=

# Global rate limit window (ms) and max requests per IP per window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Tighter limits for register/login/forgot-password (brute force / email
# bombing) and refresh (called automatically, so needs more headroom).
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
REFRESH_RATE_LIMIT_WINDOW_MS=900000
REFRESH_RATE_LIMIT_MAX=30

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Two DIFFERENT secrets — compromising one must not compromise the other.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30

# SMTP for verification/password-reset emails. Leave unset for local dev —
# emails are logged instead of sent (see src/config/mailer.js).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Wanderly <no-reply@wanderly.test>

# --- Added in later phases (payments, images) — not required yet ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# REDIS_URL=
