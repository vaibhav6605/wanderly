# Copy this file to .env and adjust if needed. .env is git-ignored.
# Vite only exposes variables prefixed with VITE_ to client code.

VITE_API_BASE_URL=http://localhost:5000/api/v1

# Cloudinary (required for image uploads in the admin tour form)
# Create an unsigned upload preset in your Cloudinary dashboard
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# Stripe (required for payment checkout)
# Get your publishable key from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
